<style>
    .hero {
        background-color: {{ section.settings.background_color | default: '#000000' }};
        display: flex;
        flex-direction: column;
        flex-wrap: wrap;
        width: 100%;
    }

    .hero__content {
        color: {{ section.settings.text_color | default: '#ffffff' }};
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 2rem;
        position: relative;
        z-index: 1;
    }

    .hero__content h1 {
        font-size: 3rem;
        margin: 1rem 0;
    }

    .hero__content p {
        font-size: 1rem;
        margin: 1rem 0 3rem 0;
    }

    .hero__image {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (min-width: 1080px) {
        .hero {
            flex-direction: row;
        }

        .hero__content {
            padding: 2rem 0 2rem 15%;
            text-align: left;
            align-items: flex-start;
        }

        .hero__content h1 {
            font-size: 4rem;
        }

        .hero__content p {
            font-size: 1.25rem;
        }

        .hero__content::after {
            background: linear-gradient(to right, {{ section.settings.background_color | default: '#000000' }}, transparent);
            content: "";
            height: 100%;
            width: 150px;
            position: absolute;
            top: 0;
            right: -150px;
        }
    }

</style>

<section class="hero">
    <div class="hero__content">
        {% if section.settings.heading %}
            <h1>
                {{ section.settings.heading }}
            </h1>
        {% endif %}
        {% if section.settings.subheading %}
            <p>
                {{ section.settings.subheading }}
            </p>
        {% endif %}
        {% if section.settings.button_text and section.settings.button_url %}
            <a href="{{ section.settings.button_url }}" class="btn btn--green">
                {{ section.settings.button_text }}
            </a>
        {% endif %}
    </div>
    <div class="hero__image">
        {% if section.settings.background_image %}
            <img src="{{ section.settings.background_image | image_url: width: 1200 }}" alt="{{ section.settings.heading }}">
        {% endif %}
    </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
        "type": "color",
        "id": "background_color",
        "label": "Background Color"
    },
    {
        "type": "color",
        "id": "text_color",
        "label": "Text Color"
    },
    {
        "type": "text",
        "id": "heading",
        "label": "Heading",
    },
    {
        "type": "textarea",
        "id": "subheading",
        "label": "Subheading",
    },
    {
        "type": "text",
        "id": "button_text",
        "label": "Button Text"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "Button URL"
    },
    {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image"
    }
  ]
}
{% endschema %}